    TabBtn.Size = UDim2.new(1, -15, 0, 32); TabBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15); TabBtn.BackgroundTransparency = 1; TabBtn.Text = "   " .. name
    TabBtn.TextColor3 = Color3.fromRGB(170, 170, 170); TabBtn.Font = Enum.Font.GothamBlack; TabBtn.TextSize = 13; TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)
