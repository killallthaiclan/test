    container.Size = UDim2.new(1, 0, 0, 38); container.BackgroundTransparency = 1; container.ClipsDescendants = true
    
    local headerBtn = Instance.new("TextButton", container)
    headerBtn.Size = UDim2.new(1, 0, 0, 38); headerBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
    headerBtn.TextColor3 = Color3.fromRGB(230, 230, 230); headerBtn.Font = Enum.Font.GothamBold; headerBtn.TextSize = 13
    headerBtn.Text = "   " .. placeholder .. " 🔽"; headerBtn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", headerBtn).CornerRadius = UDim.new(0, 6)
    ApplyPremiumGradient(headerBtn, 90)
    local hStroke = Instance.new("UIStroke", headerBtn); hStroke.Color = Color3.fromRGB(50, 50, 50)
    
    local scroll = Instance.new("ScrollingFrame", container)
    scroll.Size = UDim2.new(1, 0, 0, 130); scroll.Position = UDim2.new(0, 0, 0, 42)
    scroll.BackgroundColor3 = Color3.fromRGB(18, 18, 18); scroll.BorderSizePixel = 0; scroll.ScrollBarThickness = 0; scroll.Visible = false
    Instance.new("UICorner", scroll).CornerRadius = UDim.new(0, 6)
    local sStroke = Instance.new("UIStroke", scroll); sStroke.Color = Color3.fromRGB(60, 30, 30)
    local listLayout = Instance.new("UIListLayout", scroll)
    
    local isOpen = false
    headerBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        if isOpen then
            TweenObj(container, {Size = UDim2.new(1, 0, 0, 175)}, 0.2); scroll.Visible = true; headerBtn.Text = "   เลือกแล้วปิดหน้าต่าง 🔼"
        else
            TweenObj(container, {Size = UDim2.new(1, 0, 0, 38)}, 0.2); task.wait(0.2); scroll.Visible = false
            headerBtn.Text = _G[globalVarName] ~= "" and "   " .. _G[globalVarName] .. " 🔽" or "   " .. placeholder .. " 🔽"
        end
    end)
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton", scroll)
        optBtn.Size = UDim2.new(1, 0, 0, 32); optBtn.BackgroundTransparency = 1; optBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        optBtn.Font = Enum.Font.GothamBold; optBtn.TextSize = 12; optBtn.Text = "   " .. opt.display; optBtn.TextXAlignment = Enum.TextXAlignment.Left
        optBtn.MouseEnter:Connect(function() TweenObj(optBtn, {TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundColor3 = Color3.fromRGB(35, 20, 20), BackgroundTransparency=0}) end)
        optBtn.MouseLeave:Connect(function() TweenObj(optBtn, {TextColor3 = Color3.fromRGB(180, 180, 180), BackgroundTransparency=1}) end)
        optBtn.MouseButton1Click:Connect(function()
            _G[globalVarName] = opt.value; headerBtn.Text = "   " .. opt.value .. " 🔽"; isOpen = false
            TweenObj(container, {Size = UDim2.new(1, 0, 0, 38)}, 0.2); task.wait(0.2); scroll.Visible = false
        end)
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y) end)
end

