local function TweenObj(obj, properties, duration)
    TweenService:Create(obj, TweenInfo.new(duration or 0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), properties):Play()
end

-- ฟังก์ชันใส่ Gradient ให้ดูพรีเมียม (ทำให้สีดูมีมิติ 3D)
local function ApplyPremiumGradient(obj, rotation)
    local grad = Instance.new("UIGradient", obj)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(160, 160, 160)) -- ไล่เฉดสว่างไปมืด
    })
    grad.Rotation = rotation or 90
    return grad
end

-- ฟังก์ชันทำเส้นขีดให้มี Fade หัว-ท้าย
local function ApplyFadeLine(obj)
    local grad = Instance.new("UIGradient", obj)
    grad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(0.2, 0),
        NumberSequenceKeypoint.new(0.8, 0),
        NumberSequenceKeypoint.new(1, 1)
    })
end

local function AbbreviateNumber(number)
    if type(number) ~= "number" then return "0" end
    if number <= 0 then return "0" end
    local function formatNum(val)
        return string.format("%.2f", math.floor(val * 100) / 100):gsub("0+$", ""):gsub("%.$", "") 
    end
    if number >= 10^18 then return formatNum(number / 10^18) .. "Qi"
    elseif number >= 10^15 then return formatNum(number / 10^15) .. "Qa"
    elseif number >= 10^12 then return formatNum(number / 10^12) .. "T"
    elseif number >= 10^9 then return formatNum(number / 10^9) .. "B"
    elseif number >= 10^6 then return formatNum(number / 10^6) .. "M"
    elseif number >= 1000 then return formatNum(number / 1000) .. "K"
    else return tostring(math.floor(number)) end
end

local function CalculateTotalHP(player)
    local baseDura, infernalBuff = 0, 0
    local duraObj = player:FindFirstChild("Durability")
    if duraObj and tonumber(duraObj.Value) then baseDura = tonumber(duraObj.Value) end
    local ultFolder = player:FindFirstChild("ultimatesFolder")
    if ultFolder then
        local infernalObj = ultFolder:FindFirstChild("Infernal Health")
        if infernalObj and tonumber(infernalObj.Value) then infernalBuff = tonumber(infernalObj.Value) end
    end
    return math.floor(baseDura + (baseDura * ((infernalBuff * 15) / 100)))
end

local function CalculateTotalDamage(player)
    local baseStr, demonBuff = 0, 0
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local strObj = leaderstats:FindFirstChild("Strength")
        if strObj and tonumber(strObj.Value) then baseStr = tonumber(strObj.Value) end
    end
    local ultFolder = player:FindFirstChild("ultimatesFolder")
    if ultFolder then
        local demonObj = ultFolder:FindFirstChild("Demon Damage")
        if demonObj and tonumber(demonObj.Value) then demonBuff = tonumber(demonObj.Value) end
    end
    local baseDMG = baseStr / 15
    return math.floor(baseDMG + (baseDMG * ((demonBuff * 10) / 100)))
end

