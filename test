local function EquipHealthPets()
    task.spawn(function()
        local petsFolder, repStorage = LocalPlayer:FindFirstChild("petsFolder"), game:GetService("ReplicatedStorage")
        if not petsFolder then return end
        for _, folder in pairs(petsFolder:GetChildren()) do if folder:IsA("Folder") then for _, pet in pairs(folder:GetChildren()) do pcall(function() repStorage.rEvents.equipPetEvent:FireServer("unequipPet", pet) end) end end end
        task.wait(0.3)
        local petsToEquip = {}
        for _, folder in pairs(petsFolder:GetChildren()) do if folder:IsA("Folder") then for _, pet in pairs(folder:GetChildren()) do if pet.Name == "Mighty Monster" then table.insert(petsToEquip, pet) end end end end
        for i = 1, math.min(8, #petsToEquip) do pcall(function() repStorage.rEvents.equipPetEvent:FireServer("equipPet", petsToEquip[i]) end) task.wait(0.1) end
    end)
end

