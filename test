    local Page = Instance.new("ScrollingFrame", ContentArea)
    Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.Visible = false; Page.ScrollBarThickness = 0; Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    local PageLayout = Instance.new("UIListLayout", Page); PageLayout.Padding = UDim.new(0, 8)
    local PagePadding = Instance.new("UIPadding", Page); PagePadding.PaddingTop = UDim.new(0, 10); PagePadding.PaddingBottom = UDim.new(0, 10); PagePadding.PaddingLeft = UDim.new(0, 5); PagePadding.PaddingRight = UDim.new(0, 5)

    TabBtn.MouseEnter:Connect(function() TweenObj(TabBtn, {BackgroundColor3 = Color3.fromRGB(30, 20, 20), BackgroundTransparency = 0}) end)
    TabBtn.MouseLeave:Connect(function() TweenObj(TabBtn, {BackgroundColor3 = TabBtn.TextColor3 == Color3.fromRGB(255, 255, 255) and Color3.fromRGB(40, 15, 15) or Color3.fromRGB(15, 15, 15), BackgroundTransparency = TabBtn.TextColor3 == Color3.fromRGB(255, 255, 255) and 0 or 1}) end)
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(pages) do p.Visible = false end
        for _, b in pairs(tabButtons) do TweenObj(b, {TextColor3 = Color3.fromRGB(170, 170, 170), BackgroundColor3 = Color3.fromRGB(15, 15, 15), BackgroundTransparency = 1}) end
        Page.Visible = true
        TweenObj(TabBtn, {TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundColor3 = Color3.fromRGB(40, 15, 15), BackgroundTransparency = 0})
        local targetY = 10 + ((currentIndex - 1) * 37)
        TweenObj(ActiveIndicator, {Position = UDim2.new(0, 5, 0, targetY)}, 0.25)
    end)
    table.insert(pages, Page); table.insert(tabButtons, TabBtn)
